# ---- Git (optional, for pushing) ----
GITHUB_TOKEN=your_token_here
GITHUB_REPO_URL=https://github.com/Irfan6672/Social-Content-Management-App.git

# ---- MediaChat app ----
# Database. Dev = SQLite. Prod = PostgreSQL.
DATABASE_URL="file:./dev.db"

# NextAuth. Generate a secret with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me"

# Anthropic (server-side only). Model is swappable via env.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"

# Storage. Dev = local /uploads. Prod = R2/S3.
STORAGE_DRIVER="local"
S3_ENDPOINT=""
S3_REGION=""
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# Email. Dev logs reset links to console instead of sending.
RESEND_API_KEY=""
EMAIL_FROM="MediaChat <no-reply@mediachat.local>"
