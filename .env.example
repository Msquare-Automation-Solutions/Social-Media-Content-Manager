# ---- Git (optional, for pushing) ----
GITHUB_TOKEN=your_token_here
GITHUB_REPO_URL=https://github.com/Irfan6672/Social-Content-Management-App.git

# ---- MediaChat app ----
# Database — PostgreSQL (Neon). Use the POOLED connection string and keep
# ?sslmode=require. Example:
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth. Generate a secret with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me"

# Anthropic (server-side only). Model is swappable via env.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"

# Storage. Dev = local /uploads (STORAGE_DRIVER=local).
# Prod = Cloudflare R2 (S3-compatible): set STORAGE_DRIVER=s3 and fill these.
#   S3_ENDPOINT        = https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#   S3_REGION          = auto
#   S3_BUCKET          = your R2 bucket name
#   S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY = an R2 API token
#   S3_PUBLIC_BASE_URL = the bucket's public URL, e.g. https://pub-xxxx.r2.dev
STORAGE_DRIVER="local"
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_BASE_URL=""

# Email. Dev logs reset links to console instead of sending.
RESEND_API_KEY=""
EMAIL_FROM="MediaChat <no-reply@mediachat.local>"
