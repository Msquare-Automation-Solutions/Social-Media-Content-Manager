# Isolated database for Playwright E2E — NEVER your production database.
#
# Easiest with Neon (your app already uses it): create a branch off production
#   Neon console → your project → Branches → New branch (name it e2e-test)
# then copy that branch's connection string here. (Or set NEON_API_KEY in .env
# and let the assistant create the branch for you.)
#
# After setting this, run:
#   npm run e2e:db     # migrate + seed the test branch
#   npm run e2e        # run the suite against it (guarded against prod)
#
# This file is gitignored — do not commit real connection strings.
TEST_DATABASE_URL="postgresql://USER:PASSWORD@ep-your-branch-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require"
