// MediaChat — Prisma schema (see CLAUDE.md "Prisma model")
//
// Runs on PostgreSQL (Neon). For portability the schema keeps a couple of
// deliberate simplifications that also worked on the original SQLite dev DB:
//   - enum-like fields (role, asset type, source, chat role) are stored as
//     String and validated in application code (see src/lib/enums.ts).
//   - JSON-ish fields (tags, attachments, snapshots, artifacts) are stored as
//     String holding JSON — use the helpers in src/lib/json.ts to (de)serialize.
//   - the asset<->channel many-to-many uses the explicit AssetChannel join
//     table (already required by the spec) instead of an array column.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String
  passwordHash      String
  avatarColor       String    @default("#0e9f8f")
  createdAt         DateTime  @default(now())
  // Bumped on password reset/change to invalidate older JWT sessions.
  passwordChangedAt DateTime  @default(now())
  // Set when an admin deactivates the account — login + active sessions blocked.
  disabledAt        DateTime?

  memberships   Membership[]
  person        Person[]
  createdAssets MediaAsset[]         @relation("AssetCreatedBy")
  assetVersions AssetVersion[]
  chatSessions  ChatSession[]
  skillUpdates  Skill[]
  resetTokens   PasswordResetToken[]
  notifications Notification[]
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  memberships   Membership[]
  skills        Skill[]
  people        Person[]
  channels      SocialChannel[]
  accounts      Account[]
  assets        MediaAsset[]
  sessions      ChatSession[]
  invites       Invite[]
  activity      ActivityLog[]
  notifications Notification[]
  binItems      ContentBinItem[]
  tasks         Task[]
  taskTypes     TaskType[]
}

// Immutable audit trail of who did what. Actor fields are denormalized so an
// entry stays readable even after the actor/target is deleted (no FK).
model ActivityLog {
  id               String   @id @default(cuid())
  workspaceId      String
  actorId          String
  actorName        String
  actorAvatarColor String
  action           String // e.g. "asset.created" (validated in src/lib/activity.ts)
  category         String // content | account | creator | platform
  targetType       String?
  targetId         String?
  targetLabel      String?
  metadata         String? // JSON
  createdAt        DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
}

// In-app notification (bell). Delivered to a single recipient user. Actor +
// target fields are denormalized (like ActivityLog) and `message` is a pre-
// rendered summary so the bell dropdown renders without extra lookups.
model Notification {
  id               String    @id @default(cuid())
  workspaceId      String
  recipientId      String
  actorId          String
  actorName        String
  actorAvatarColor String
  action           String // e.g. "asset.approved" | "asset.reworked" | "asset.published"
  targetType       String?
  targetId         String?
  targetLabel      String?
  message          String // pre-rendered, e.g. "approved “Launch teaser”"
  readAt           DateTime?
  createdAt        DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  recipient User      @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, readAt, createdAt])
}

// role: OWNER | ADMIN | EDITOR | VIEWER  (validated in app)
model Membership {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  role        String
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model Skill {
  id           String   @id @default(cuid())
  workspaceId  String
  name         String
  systemPrompt String
  updatedById  String?
  updatedAt    DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  updatedBy User?     @relation(fields: [updatedById], references: [id])
}

// A creator/company person. May link to a login User, or stand alone.
model Person {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  email       String?
  label       String?
  userId      String?
  avatarColor String    @default("#0e9f8f")
  createdAt   DateTime  @default(now())
  // Soft-delete: archived creators disappear from pickers/filters but stay
  // referenced by past assets (attribution history is preserved).
  deletedAt   DateTime?

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?        @relation(fields: [userId], references: [id])
  assets    MediaAsset[]
}

model SocialChannel {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  icon        String
  color       String   @default("#0e9f8f")
  createdAt   DateTime @default(now())

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assets    AssetChannel[]
}

// The account a piece of content is filed under (e.g. Faasil, Jahar, Msquare,
// AI Lab). Admin-editable taxonomy, many-to-many with assets. Soft-deleted so
// archiving an account keeps it off pickers without breaking past attribution.
model Account {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  icon        String    @default("✨") // emoji fallback; some names map to a brand mark
  color       String    @default("#0e9f8f")
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assets    AssetAccount[]
}

// A raw idea captured in the Content Bin — a link/thread/topic/screenshot the
// team wants to keep before it becomes finished content. Lives apart from
// MediaAsset (the finished library); "Promote" copies a bin item into a
// MediaAsset (see promotedAssetId). Optional taxonomy is captured up front so
// promotion is one-click. JSON-string columns follow the schema's convention.
// status: NEW | USED | DISCARDED  (validated in src/lib/enums.ts)
model ContentBinItem {
  id              String    @id @default(cuid())
  workspaceId     String
  createdById     String // User.id who captured it
  links           String    @default("[]") // JSON string[] of reference URLs
  title           String
  note            String    @default("")
  tags            String    @default("[]") // JSON string[]
  status          String    @default("NEW")
  personId        String? // Person/creator (optional; not a hard FK)
  category        String? // ASSET_TYPES value
  channelIds      String    @default("[]") // JSON string[] of SocialChannel ids
  accountIds      String    @default("[]") // JSON string[] of Account ids
  screenshots     String    @default("[]") // JSON string[] of R2 image urls; [0] is the cover
  promotedAssetId String? // set when promoted → MediaAsset
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt
  deletedAt       DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status, createdAt])
}

// type: IMAGE | THUMBNAIL | VIDEO | BLOGPOST | VIDEO_SCRIPT
// source: UPLOAD | GENERATED
model MediaAsset {
  id            String    @id @default(cuid())
  workspaceId   String
  personId      String
  createdById   String
  type          String
  title         String
  filename      String?
  url           String?
  thumbnailUrl  String?
  mimeType      String?
  sizeBytes     Int?
  html          String?
  tags          String    @default("[]") // JSON string[]
  note          String? // free-text note (e.g. describing an "Other"-category asset)
  source        String
  chatMessageId String?
  status        String    @default("PENDING") // PENDING | REWORK | APPROVED | PUBLISHED
  reviewNote    String? // admin's rework comment
  reviewedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
  deletedAt     DateTime?

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  person    Person         @relation(fields: [personId], references: [id])
  createdBy User           @relation("AssetCreatedBy", fields: [createdById], references: [id])
  message   ChatMessage?   @relation(fields: [chatMessageId], references: [id])
  channels  AssetChannel[]
  accounts  AssetAccount[]
  versions  AssetVersion[]
  taskLinks TaskAsset[]
}

model AssetChannel {
  assetId      String
  channelId    String
  scheduledFor DateTime? // planned post date for this asset on this platform

  asset   MediaAsset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  channel SocialChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@id([assetId, channelId])
}

model AssetAccount {
  assetId   String
  accountId String

  asset   MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  account Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@id([assetId, accountId])
}

model AssetVersion {
  id           String   @id @default(cuid())
  assetId      String
  snapshotJson String // JSON snapshot of the asset before an edit
  editedById   String
  createdAt    DateTime @default(now())

  asset    MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  editedBy User       @relation(fields: [editedById], references: [id])
}

model ChatSession {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  title       String
  createdAt   DateTime  @default(now())
  archivedAt  DateTime?

  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]
}

// role: user | assistant  (validated in app)
model ChatMessage {
  id           String   @id @default(cuid())
  sessionId    String
  role         String
  content      String
  attachments  String   @default("[]") // JSON string[]
  artifactJson String? // JSON artifact payload
  createdAt    DateTime @default(now())

  session ChatSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  assets  MediaAsset[]
}

model Invite {
  id          String    @id @default(cuid())
  workspaceId String
  email       String
  role        String
  token       String    @unique
  expiresAt   DateTime
  acceptedAt  DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// A planned content piece from the weekly calendar (see MSQ content calendar).
// Created in "Content Overview" (theme/brief/content), then it runs through
// production stages (Content/Video/Graphics — decided by contentType), then
// Publishing then Analytics. See src/lib/tasks.ts for the stage config.
// currentStage: CONTENT|VIDEO|GRAPHICS|PUBLISHING|ANALYTICS|DONE
// publishStatus: NOT_PUBLISHED|PENDING|PUBLISHED_ON_TIME|PUBLISHED_DELAY
model Task {
  id            String    @id @default(cuid())
  workspaceId   String
  createdById   String
  title         String // content theme
  brief         String    @default("")
  content       String    @default("") // drafted copy/script
  remarks       String    @default("")
  contentType   String
  channelId     String? // SocialChannel (platform)
  accountId     String? // Account
  weekLabel     String    @default("")
  plannedDate   DateTime?
  currentStage  String    @default("CONTENT")
  publishStatus String    @default("NOT_PUBLISHED")
  publishedDate DateTime?
  contentLink   String?
  metricClicks  Int?
  metricLeads   Int?
  metricEng     Int?
  metricsNote   String?
  binItemId     String? // linked Content Bin idea
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
  deletedAt     DateTime?

  workspace Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stages    TaskStage[]
  assets    TaskAsset[]

  @@index([workspaceId, currentStage, deletedAt])
}

// One production stage of a task, owned by a member (login user) who is
// notified on assignment. workStatus: YTI|WIP_ON_TRACK|WIP_DELAY|
// COMPLETED_ON_TIME|COMPLETED_DELAY. reviewStatus: NOT_SUBMITTED|PENDING|
// APPROVED|REWORK.
model TaskStage {
  id            String    @id @default(cuid())
  taskId        String
  stage         String
  order         Int       @default(0)
  assigneeId    String? // User.id
  targetDate    DateTime?
  workStatus    String    @default("YTI")
  reviewStatus  String    @default("NOT_SUBMITTED")
  submittedAt   DateTime?
  completedDate DateTime?
  reviewNote    String?
  reviewedAt    DateTime?
  remarks       String    @default("")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([assigneeId, reviewStatus])
}

// Admin-editable content types for the task pipeline (Reels, Article, …).
// Replaces the old hardcoded config; each task picks a type by name and its
// own stages. Soft-deleted so archiving keeps past tasks readable.
model TaskType {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, deletedAt])
}

model TaskAsset {
  taskId  String
  assetId String
  stageId String? // which production stage this file was submitted for (null = task-level)

  task  Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  asset MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@id([taskId, assetId])
}
